# Shared LLM registry
# Prefer a structured registry instead of the legacy single-provider shape.
LLM_REGISTRY_PATH=./config/llm_registry.example.json

# Provider secrets referenced by the registry
MINIMAX_API_KEY=your-minimax-api-key-here
ANTHROPIC_API_KEY_PRIMARY=your-anthropic-api-key-here
ANTHROPIC_API_KEY_SECONDARY=your-second-anthropic-api-key-here
GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here

# Optional legacy compatibility variables
# LLM_PROVIDER_CONTRACT=openai_compatible
# LLM_BASE_URL=https://api.minimaxi.chat/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=your-model-name-here

# Optional per-profile overrides in legacy mode
# LLM_DATASET_REVIEW_MODEL=claude-opus-4-6
# LLM_EVAL_JUDGE_MODEL=claude-opus-4-6

# Tavily Search API
TAVILY_API_KEY=your-tavily-api-key-here

# Product defaults
UPLOAD_MAX_BYTES=104857600

# Local API server
BACKEND_RUNTIME_ROOT=.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
