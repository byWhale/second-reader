# Shared LLM registry
# Default local setup: explicit profiles over the current Minimax-compatible Anthropic endpoint.
LLM_REGISTRY_PATH=./config/llm_registry.minimax_legacy_compatible.json

# Default provider secrets referenced by the compat registry
LLM_API_KEY=your-api-key-here
LLM_MODEL=MiniMax-M2.5
# Optional extra key slot for the same provider
# LLM_API_KEY_SECONDARY=your-second-api-key-here
# Optional per-profile model overrides
# LLM_DATASET_REVIEW_MODEL=MiniMax-M2.5
# LLM_EVAL_JUDGE_MODEL=MiniMax-M2.5

# Alternative multi-provider example
# LLM_REGISTRY_PATH=./config/llm_registry.example.json
# MINIMAX_API_KEY=your-minimax-api-key-here
# ANTHROPIC_API_KEY_PRIMARY=your-anthropic-api-key-here
# ANTHROPIC_API_KEY_SECONDARY=your-second-anthropic-api-key-here
# GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here

# Tavily Search API
TAVILY_API_KEY=your-tavily-api-key-here

# Product defaults
UPLOAD_MAX_BYTES=104857600

# Local API server
BACKEND_RUNTIME_ROOT=.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
